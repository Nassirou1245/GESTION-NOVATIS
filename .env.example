# NPMS Enterprise — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored and must NEVER be committed.
#
# On Vercel: set these in Project → Settings → Environment Variables.
# The build command (node build.js) reads them automatically.
# ─────────────────────────────────────────────────────────────────────────────

# Your Supabase project URL (found in Supabase → Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase ANON (public) key — NOT the service_role key
# Found in Supabase → Settings → API → Project API keys → anon / public
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
